{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/styles/*": ["./src/styles/*"],
      "@flux/plugin-sdk": ["./plugins/sdk/src/index.ts"],
      "@flux/plugin-sdk/types": ["./plugins/sdk/src/types.ts"],
      "@flux/plugin-sdk/host": ["./plugins/sdk/src/host.ts"],
      "@flux/plugin-sdk/layout": ["./plugins/sdk/src/layout.tsx"],
      "@flux/plugin-sdk/drag": ["./plugins/sdk/src/drag.ts"],
      "@flux/plugin-sdk/ui": ["./plugins/sdk/src/ui.ts"],
      "@flux/plugin-kanban": ["./plugins/kanban/src/index.ts"],
      "@flux/plugin-canvas": ["./plugins/canvas/src/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "plugins", "tests"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
