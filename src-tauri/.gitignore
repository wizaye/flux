# ─────────────────────────────────────────────────────────────────────────
# Flux backend (Tauri + Rust) — .gitignore
# Root .gitignore handles JS / Vite / OS noise.
# ─────────────────────────────────────────────────────────────────────────

# ── Cargo build artefacts ────────────────────────────────────────────────
/target/
**/*.rs.bk
*.pdb
/Cargo.lock.bak

# Per-flycheck (rust-analyzer save-check) crates dropped into target.
/flycheck0/
/flycheck1/

# ── Tauri generated content ──────────────────────────────────────────────
# Schema files are emitted by tauri-build on every cargo invocation.
/gen/schemas/

# Production bundle output (msi/dmg/AppImage/etc.) lives under target/.
# Belt-and-braces in case anyone uses a custom dist-dir.
/release/
/bundle/

# Tauri sidecar binaries — usually downloaded at build time, never
# committed; if a developer drops one here by mistake we don't ship
# it. Whitelist with `!binaries/<name>` if a real sidecar exists.
/binaries/

# ── Windows installer scratch ────────────────────────────────────────────
WixTools/
*.wixobj
*.wixpdb

# ── Local SQLite test artefacts ──────────────────────────────────────────
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.db
*.db-wal
*.db-shm

# ── Local secrets / signing keys ─────────────────────────────────────────
*.pem
*.p12
*.pfx
*.key
*.keystore
tauri-key.json
private.key
