{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flux",
  "version": "0.1.0",
  "identifier": "com.vijayendhergatla.flux",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "flux",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#1e1e1e",
        "dragDropEnabled": false
      }
        
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
