# ─────────────────────────────────────────────────────────────────────────
# Flux — root .gitignore
#
# Layered: keep this file focused on JS/TS host + workspace-wide noise.
# Rust + Tauri build outputs live in `src-tauri/.gitignore`.
# ─────────────────────────────────────────────────────────────────────────

# ── Dependencies ─────────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/
.pnpm-store/
jspm_packages/

# ── Build output (Vite, Vitest, TS) ──────────────────────────────────────
dist/
dist-ssr/
build/
out/
*.tsbuildinfo
.vite/
.vite-cache/
.cache/

# ── Cargo build output (any crate, anywhere in the workspace) ────────────
# src-tauri/.gitignore handles its own /target/ specifically; this rule
# is a safety net so any future Rust crate (plugin sidecar, helper
# binary, examples/) under the workspace can't accidentally commit
# multi-GB compile artefacts.
target/
**/target/
**/Cargo.lock.bak
**/*.rs.bk

# ── Tauri release artefacts (release binaries / installers / bundles) ────
# These can be hundreds of MB each. NEVER commit them — release flows
# upload to GitHub Releases or an artifact store, not the repo.
release/
releases/
bundle/
bundles/
**/target/release/
**/target/debug/
**/target/aarch64-*/
**/target/x86_64-*/
**/target/wasm32-*/
src-tauri/gen/schemas/

# ── Large binary artefacts (catch-all by extension) ──────────────────────
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj
*.pdb
*.rlib
*.rmeta
*.app
*.dmg
*.pkg
*.deb
*.rpm
*.snap
*.AppImage
*.msi
*.nsis
*.wixpdb
*.wixobj
WixTools/


# ── Tests / coverage ─────────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/
__snapshots__/__diff_output__/

# ── Lint / formatter caches ──────────────────────────────────────────────
.eslintcache
.stylelintcache
.prettiercache

# ── Logs ─────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Secrets / env ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local
.secret
.secrets/

# ── Editor / IDE ─────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
\#*\#
.\#*

# ── OS junk ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ── Tauri release artefacts (in case they leak out of src-tauri/target) ──
# Kept loose so anything that ends up at the workspace root is also
# rejected. Extension list intentionally overlaps with the Cargo block
# above — git only needs to match once.
*.tar.gz
*.tar.xz
*.zip
*.7z

# ── Per-developer local files ────────────────────────────────────────────
*.local.json
local.settings.json
.history/
.scratch/
TODO.local.md

# ── Flux runtime artefacts (never check in a real user vault) ────────────
.zenvault/
*.zenvault/

