{
  "name": "@flux/plugin-excalidraw",
  "version": "0.1.0",
  "private": true,
  "description": "Excalidraw whiteboards for Flux. Wraps the official @excalidraw/excalidraw SDK; files are stored as plain *.excalidraw JSON in your vault and round-trip with the Excalidraw web app.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./manifest.json",
    "./sidebar": "./src/sidebar.tsx",
    "./view": "./src/view.tsx",
    "./settings": "./src/settings.tsx"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@flux/plugin-sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  }
}
