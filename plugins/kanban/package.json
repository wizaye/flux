{
  "name": "@flux/plugin-kanban",
  "version": "0.1.0",
  "private": true,
  "description": "First-party kanban plugin for Flux. Jira-style work items (custom types, fields, parent/child) stored as `*.board.yaml`; any Markdown note can link to a work item.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./manifest.json",
    "./sidebar": "./src/sidebar.tsx",
    "./view": "./src/view.tsx",
    "./settings": "./src/settings.tsx",
    "./app-root": "./src/app-root.tsx"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@flux/plugin-sdk": "workspace:*",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  }
}
