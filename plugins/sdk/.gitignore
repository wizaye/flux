# Build artefact.
dist/

# Generated by `pnpm run vendor-ui` (pre-build step). Tracked
# under .gitignore so the host shadcn primitives stay the single
# source of truth — drift between `src/components/ui/*` and
# `src/ui-vendored/*` is impossible because the script always
# overwrites the latter from the former.
src/ui-vendored/
src/ui-bundle.ts
src/lib/

# Tooling.
node_modules/
*.log
.DS_Store
