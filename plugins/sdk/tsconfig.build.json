{
  "extends": "../../tsconfig.plugin-base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/bridge.ts", "src/ui.ts", "node_modules", "dist"]
}
