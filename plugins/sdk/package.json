{
  "name": "@flux/plugin-sdk",
  "version": "1.0.0-rc.1",
  "private": true,
  "description": "Shared types, capability constants, and host bridge for Flux plugins. Every plugin imports from here; nothing in this package depends on host internals.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./host": "./src/host.ts",
    "./contract": "./src/contract.ts",
    "./layout": "./src/layout.tsx",
    "./drag": "./src/drag.ts",
    "./ui": "./src/ui.ts",
    "./bridge": "./src/bridge.ts"
  },
  "scripts": {
    "vendor-ui": "node scripts/vendor-ui.mjs",
    "build": "pnpm run vendor-ui && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "src",
    "!src/bridge.ts",
    "!src/ui.ts",
    "!src/ui-vendored/**",
    "!src/ui-bundle.ts",
    "!src/lib/**",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "radix-ui": "^1.5.0",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./host": {
        "types": "./dist/host.d.ts",
        "import": "./dist/host.js"
      },
      "./contract": {
        "types": "./dist/contract.d.ts",
        "import": "./dist/contract.js"
      },
      "./layout": {
        "types": "./dist/layout.d.ts",
        "import": "./dist/layout.js"
      },
      "./drag": {
        "types": "./dist/drag.d.ts",
        "import": "./dist/drag.js"
      },
      "./ui": {
        "types": "./dist/ui-bundle.d.ts",
        "import": "./dist/ui-bundle.js"
      }
    }
  }
}
